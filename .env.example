# Copy to .env and fill in. .env is gitignored — never commit it.
# Every source is optional; the site degrades cleanly without any of them.
# After editing, run:  node scripts/check-setup.mjs

# ── Goodreads ────────────────────────────────────────────────────────────
# The number in your profile URL:
#   goodreads.com/user/show/12345678-brooks  →  12345678
# Your "read" and "currently-reading" shelves must be public.
GOODREADS_USER_ID=

# Only needed if your shelves are NOT public. Take the key= parameter from
# the RSS link at the bottom of your shelf page.
GOODREADS_RSS_KEY=

# Goodreads does not publish reading progress in its feed, so the page you are
# on cannot be read from it. Set this to show "Page 210 of 656" on the book you
# are currently reading; leave empty to show the book length instead.
GOODREADS_CURRENT_PAGE=

# ── Letterboxd ───────────────────────────────────────────────────────────
# Just your username, no @.
LETTERBOXD_USER=

# ── Spotify ──────────────────────────────────────────────────────────────
# developer.spotify.com/dashboard → Create app.
# Redirect URI: http://127.0.0.1:8888/callback
# Then: node scripts/spotify-token.mjs
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# ── osu! ─────────────────────────────────────────────────────────────────
# osu.ppy.sh/home/account/edit → OAuth → New application.
# Callback URL can be anything, it is not used (client credentials grant).
OSU_CLIENT_ID=
OSU_CLIENT_SECRET=
OSU_USER=

# ── MyAnimeList ──────────────────────────────────────────────────────────
# myanimelist.net/apiconfig → Create ID. Only the client ID is used; the
# secret is not needed for reading public lists.
# Your lists must be public: MyAnimeList → Settings → Privacy.
MAL_CLIENT_ID=
MAL_USER=
